 check process postgresql with pidfile /var/run/postgresql/%%PG_VERSION%%-main.pid
   group postgresql
   start program = "/usr/bin/systemctl start postgresql" with timeout 60 seconds
   stop  program = "/usr/bin/systemctl stop postgresql" with timeout 60 seconds
   if failed unixsocket /var/run/postgresql/.s.PGSQL.5432 protocol pgsql then restart
   if failed unixsocket /var/run/postgresql/.s.PGSQL.5432 protocol pgsql then alert
   if failed host 127.0.0.1 port 5432 protocol pgsql then restart
   if failed host 127.0.0.1 port 5432 protocol pgsql then alert
   if 5 restarts within 5 cycles then timeout
   depend postgresql_bin
 check file postgresql_bin with path /usr/lib/postgresql/%%PG_VERSION%%/bin/postgres
   group postgresql
   include /etc/monit/templates/rootbin
