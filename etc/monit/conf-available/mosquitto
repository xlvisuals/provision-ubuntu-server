# mosquitto
check process mosquitto matching /usr/sbin/mosquitto
  group cache
  group mosquitto
  start program = "/usr/bin/systemctl start mosquitto" with timeout 60 seconds
  stop program  = "/usr/bin/systemctl start mosquitto" with timeout 60 seconds
#  if failed host localhost port 1883 protocol mysql with timeout 15 seconds for 3 times within 4 cycles then restart
  if totalmem > 200 Mb then alert
  if totalmem > 500 Mb then restart
  if cpu > 60% for 2 cycles then alert
  if cpu > 98% for 5 cycles then restart
  if 2 restarts within 2 cycles then alert
  depend mosquitto_bin

check file mosquitto_bin with path /usr/sbin/mosquitto
  group mosquitto
  include /etc/monit/templates/rootbin